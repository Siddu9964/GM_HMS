                                OR (d.out_time IS NULL AND CURTIME() >= d.in_time)
                                OR (d.out_time < d.in_time AND (CURTIME() >= d.in_time OR CURTIME() <= d.out_time))
                            ) THEN 'Available'
                            ELSE 'Off-Duty'
                        END AS availability
                    FROM doctors d WHERE (d.status = 'Active' OR d.status IS NULL OR d.status = '') ORDER BY availability DESC, d.full_name ASC LIMIT ? PARAMS: [100]

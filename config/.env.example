# ========================================
# ENVIRONMENT CONFIGURATION
# ========================================
# Copy this file to .env and fill in your actual values
# NEVER commit .env to version control!

# Environment Type: development, staging, production
APP_ENV=development
APP_DEBUG=true
APP_NAME="GM Hospital Management System"

# ========================================
# DATABASE CONFIGURATION
# ========================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=hmsci
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4

# Database Connection Pool
DB_POOL_MIN=2
DB_POOL_MAX=10

# ========================================
# SECURITY KEYS
# ========================================
# Generate these using: php setup/generate_keys.php
# IMPORTANT: Use different keys for each environment!

# JWT Secret (min 64 characters)
JWT_SECRET=CHANGE_THIS_TO_A_RANDOM_64_CHARACTER_STRING_FOR_JWT_SIGNING

# Encryption Key (32 bytes, base64 encoded)
ENCRYPTION_KEY=CHANGE_THIS_TO_A_BASE64_ENCODED_32_BYTE_KEY

# CSRF Secret
CSRF_SECRET=CHANGE_THIS_TO_A_RANDOM_STRING_FOR_CSRF_TOKENS

# Password Salt (for additional hashing)
PASSWORD_SALT=CHANGE_THIS_TO_A_RANDOM_SALT_STRING

# ========================================
# JWT CONFIGURATION
# ========================================
JWT_ISSUER=gm-hms
JWT_AUDIENCE=gm-hms-api
JWT_ACCESS_TOKEN_EXPIRE=3600
JWT_REFRESH_TOKEN_EXPIRE=2592000
JWT_ALGORITHM=HS256

# ========================================
# SESSION CONFIGURATION
# ========================================
SESSION_LIFETIME=7200
SESSION_NAME=GM_HMS_SESSION
SESSION_SECURE=true
SESSION_HTTPONLY=true
SESSION_SAMESITE=Strict

# ========================================
# RATE LIMITING
# ========================================
# Requests per minute per user
RATE_LIMIT_PER_USER=100

# Requests per minute per IP (unauthenticated)
RATE_LIMIT_PER_IP=60

# Login attempts before lockout
MAX_LOGIN_ATTEMPTS=5

# Lockout duration in seconds
LOCKOUT_DURATION=900

# ========================================
# SECURITY HEADERS
# ========================================
# Content Security Policy
CSP_DEFAULT_SRC="'self'"
CSP_SCRIPT_SRC="'self' 'unsafe-inline'"
CSP_STYLE_SRC="'self' 'unsafe-inline'"
CSP_IMG_SRC="'self' data: https:"
CSP_FONT_SRC="'self'"

# HSTS Max Age (in seconds)
HSTS_MAX_AGE=31536000

# ========================================
# CORS CONFIGURATION
# ========================================
# Comma-separated list of allowed origins
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:3000

# Allowed methods
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS

# Allowed headers
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With

# Allow credentials
CORS_ALLOW_CREDENTIALS=true

# ========================================
# LOGGING
# ========================================
LOG_LEVEL=info
LOG_PATH=../logs
LOG_MAX_FILES=30
LOG_MAX_SIZE=10485760

# Security event logging
SECURITY_LOG_ENABLED=true
AUDIT_LOG_ENABLED=true

# ========================================
# EMAIL CONFIGURATION
# ========================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_ENCRYPTION=tls
SMTP_FROM_EMAIL=noreply@gm-hms.com
SMTP_FROM_NAME="GM HMS"

# ========================================
# ENCRYPTION SETTINGS
# ========================================
# Encrypt sensitive data at rest
ENCRYPT_SENSITIVE_DATA=true

# Fields to encrypt (comma-separated)
ENCRYPTED_FIELDS=ssn,credit_card,bank_account

# ========================================
# API CONFIGURATION
# ========================================
API_VERSION=v1
API_PREFIX=/api

# API Key for server-to-server communication
API_KEY=CHANGE_THIS_TO_A_SECURE_API_KEY

# ========================================
# HTTPS ENFORCEMENT
# ========================================
# Force HTTPS redirect (set to false for local development)
FORCE_HTTPS=false

# Trust proxy headers (for load balancers)
TRUST_PROXY=false

# ========================================
# BOT PROTECTION
# ========================================
# Enable bot detection
BOT_DETECTION_ENABLED=true

# Honeypot field name
HONEYPOT_FIELD_NAME=website_url

# Challenge threshold (suspicious requests before challenge)
BOT_CHALLENGE_THRESHOLD=10

# ========================================
# PASSWORD POLICY
# ========================================
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SPECIAL_CHARS=true
PASSWORD_HISTORY_COUNT=5

# ========================================
# FILE UPLOAD SECURITY
# ========================================
MAX_UPLOAD_SIZE=5242880
ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf,doc,docx
UPLOAD_PATH=../uploads

# ========================================
# IP WHITELIST/BLACKLIST
# ========================================
# Comma-separated IP addresses
IP_WHITELIST=
IP_BLACKLIST=

# ========================================
# MAINTENANCE MODE
# ========================================
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE="System is under maintenance. Please try again later."

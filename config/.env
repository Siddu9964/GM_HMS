# ========================================
# ENVIRONMENT CONFIGURATION
# ========================================
APP_ENV=development
APP_DEBUG=true
APP_NAME="GM Hospital Management System"

# ========================================
# DATABASE CONFIGURATIONok do it 
# ========================================
DB_HOST=localhost
DB_PORT=3306
DB_NAME=hmsci
DB_USERNAME=root
DB_PASSWORD=
DB_CHARSET=utf8mb4

# Database Connection Pool
DB_POOL_MIN=2
DB_POOL_MAX=10

# ========================================
# SECURITY KEYS
# ========================================
# IMPORTANT: Generate new keys for production!
# Use: php setup/generate_keys.php

JWT_SECRET=dev_jwt_secret_key_change_this_in_production_min_64_chars_required
ENCRYPTION_KEY=dev_encryption_key_32_bytes_change_in_production_environment
CSRF_SECRET=dev_csrf_secret_change_this_in_production
PASSWORD_SALT=dev_password_salt_change_this_in_production

# ========================================
# JWT CONFIGURATION
# ========================================
JWT_ISSUER=gm-hms
JWT_AUDIENCE=gm-hms-api
JWT_ACCESS_TOKEN_EXPIRE=3600
JWT_REFRESH_TOKEN_EXPIRE=2592000
JWT_ALGORITHM=HS256

# ========================================
# SESSION CONFIGURATION
# ========================================
SESSION_LIFETIME=7200
SESSION_NAME=GM_HMS_SESSION
SESSION_SECURE=false
SESSION_HTTPONLY=true
SESSION_SAMESITE=Strict

# ========================================
# RATE LIMITING
# ========================================
RATE_LIMIT_PER_USER=100
RATE_LIMIT_PER_IP=60
MAX_LOGIN_ATTEMPTS=5
LOCKOUT_DURATION=900

# ========================================
# SECURITY HEADERS
# ========================================
CSP_DEFAULT_SRC='self'
CSP_SCRIPT_SRC='self' 'unsafe-inline'
CSP_STYLE_SRC='self' 'unsafe-inline'
CSP_IMG_SRC='self' data: https:
CSP_FONT_SRC='self'
HSTS_MAX_AGE=31536000

# ========================================
# CORS CONFIGURATION
# ========================================
CORS_ALLOWED_ORIGINS=http://localhost,http://localhost:3000
CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
CORS_ALLOWED_HEADERS=Content-Type,Authorization,X-Requested-With
CORS_ALLOW_CREDENTIALS=true

# ========================================
# LOGGING
# ========================================
LOG_LEVEL=info
LOG_PATH=../logs
LOG_MAX_FILES=30
LOG_MAX_SIZE=10485760
SECURITY_LOG_ENABLED=true
AUDIT_LOG_ENABLED=true

# ========================================
# EMAIL CONFIGURATION
# ========================================
# To send real emails, fill SMTP_USERNAME and SMTP_PASSWORD below.
# For Gmail: use your Gmail address + an App Password (not your login password).
# Generate App Password: Google Account → Security → 2-Step Verification → App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=siddeshbmbeenehalli@gmail.com
SMTP_PASSWORD=ybqpnjcqfjcpyfvx
SMTP_ENCRYPTION=tls
SMTP_FROM_EMAIL=noreply@gm-hms.com
SMTP_FROM_NAME="GM Hospital"

# ========================================
# ENCRYPTION SETTINGS
# ========================================
ENCRYPT_SENSITIVE_DATA=true
ENCRYPTED_FIELDS=ssn,credit_card,bank_account

# ========================================
# API CONFIGURATION
# ========================================
API_VERSION=v1
API_PREFIX=/api
API_KEY=dev_api_key_change_this_in_production

# ========================================
# HTTPS ENFORCEMENT
# ========================================
FORCE_HTTPS=false
TRUST_PROXY=false

# ========================================
# BOT PROTECTION
# ========================================
BOT_DETECTION_ENABLED=true
HONEYPOT_FIELD_NAME=website_url
BOT_CHALLENGE_THRESHOLD=10

# ========================================
# PASSWORD POLICY
# ========================================
PASSWORD_MIN_LENGTH=8
PASSWORD_REQUIRE_UPPERCASE=true
PASSWORD_REQUIRE_LOWERCASE=true
PASSWORD_REQUIRE_NUMBERS=true
PASSWORD_REQUIRE_SPECIAL_CHARS=true
PASSWORD_HISTORY_COUNT=5

# ========================================
# FILE UPLOAD SECURITY
# ========================================
MAX_UPLOAD_SIZE=5242880
ALLOWED_FILE_TYPES=jpg,jpeg,png,pdf,doc,docx
UPLOAD_PATH=../uploads

# ========================================
# IP WHITELIST/BLACKLIST
# ========================================
IP_WHITELIST=
IP_BLACKLIST=

# ========================================
# MAINTENANCE MODE
# ========================================
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE="System is under maintenance. Please try again later."
